<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gerenciar Produtos - QueTal.me</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
    .card-shadow { box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.2); }
    .btn-green { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
    .btn-green:hover { background: linear-gradient(135deg, #059669 0%, #047857 100%); }
    .spinner { animation: spin 1s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .fade-in { animation: fadeIn 0.3s ease-in-out; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .product-card:hover { transform: translateY(-2px); box-shadow: 0 8px 25px -5px rgba(0, 0, 0, 0.15); }
  </style>
</head>
<body class="min-h-screen bg-gray-100">
  
  <!-- Header -->
  <header class="gradient-bg text-white py-4 px-6 shadow-lg">
    <div class="max-w-4xl mx-auto flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-2xl">📦</span>
        <div>
          <h1 class="font-bold text-lg" id="headerTitle">Meus Produtos</h1>
          <p class="text-sm text-green-100" id="headerSubtitle">Carregando...</p>
        </div>
      </div>
      <button onclick="abrirModal()" class="bg-white/20 hover:bg-white/30 px-4 py-2 rounded-xl font-medium transition-all flex items-center gap-2">
        <span>➕</span> <span data-i18n="btn_novo">Novo</span>
      </button>
    </div>
  </header>

  <!-- Container Principal -->
  <main class="max-w-4xl mx-auto p-4 md:p-6">
    
    <!-- Filtros -->
    <div class="bg-white rounded-xl p-4 mb-4 card-shadow flex flex-wrap gap-3 items-center">
      <div class="flex-1 min-w-[200px]">
        <input 
          type="text" 
          id="busca" 
          placeholder="🔍 Buscar produto..."
          class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-green-500"
          oninput="filtrarProdutos()"
        >
      </div>
      <select id="filtroCategoria" onchange="filtrarProdutos()" class="px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-green-500">
        <option value="">Todas categorias</option>
      </select>
      <select id="filtroStatus" onchange="filtrarProdutos()" class="px-4 py-2 border border-gray-200 rounded-lg focus:outline-none focus:border-green-500">
        <option value="">Todos status</option>
        <option value="Disponível">✅ Disponível</option>
        <option value="Indisponível">❌ Indisponível</option>
      </select>
    </div>

    <!-- Lista de Produtos -->
    <div id="listaProdutos" class="space-y-3">
      <!-- Loading -->
      <div id="loading" class="text-center py-12">
        <div class="inline-block w-8 h-8 border-4 border-green-500 border-t-transparent rounded-full spinner"></div>
        <p class="text-gray-500 mt-2">Carregando produtos...</p>
      </div>
    </div>

    <!-- Vazio -->
    <div id="vazio" class="hidden text-center py-12">
      <span class="text-6xl">📭</span>
      <p class="text-gray-500 mt-4 text-lg" data-i18n="empty_msg">Nenhum produto cadastrado</p>
      <button onclick="abrirModal()" class="mt-4 btn-green text-white px-6 py-3 rounded-xl font-medium">
        ➕ <span data-i18n="btn_add_first">Adicionar primeiro produto</span>
      </button>
    </div>

  </main>

  <!-- Modal Produto -->
  <div id="modal" class="fixed inset-0 bg-black/50 hidden items-center justify-center p-4 z-50">
    <div class="bg-white rounded-2xl w-full max-w-md card-shadow fade-in max-h-[90vh] overflow-y-auto">
      
      <!-- Header Modal -->
      <div class="flex items-center justify-between p-4 border-b">
        <h2 id="modalTitulo" class="font-bold text-lg">Novo Produto</h2>
        <button onclick="fecharModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
      </div>

      <!-- Form -->
      <form id="formProduto" class="p-4 space-y-4">
        <input type="hidden" id="produtoId" value="">
        <input type="hidden" id="produtoRow" value="">

        <!-- Nome -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Nome do Produto *</label>
          <input 
            type="text" 
            id="produtoNome" 
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:border-green-500"
            placeholder="Ex: Pizza Margherita"
          >
        </div>

        <!-- Preço e Categoria -->
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Preço (Gs.) *</label>
            <input 
              type="text" 
              id="produtoPreco" 
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:border-green-500"
              placeholder="25000"
              oninput="formatarPreco(this)"
            >
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Categoria *</label>
            <input 
              type="text" 
              id="produtoCategoria" 
              required
              list="categoriasLista"
              class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:border-green-500"
              placeholder="Ex: Pizzas"
            >
            <datalist id="categoriasLista"></datalist>
          </div>
        </div>

        <!-- Descrição -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
          <textarea 
            id="produtoDescricao" 
            rows="2"
            class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:border-green-500 resize-none"
            placeholder="Descrição opcional do produto..."
          ></textarea>
        </div>

        <!-- Status -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="produtoStatus" value="Disponível" checked class="w-4 h-4 text-green-500">
              <span>✅ Disponível</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="produtoStatus" value="Indisponível" class="w-4 h-4 text-green-500">
              <span>❌ Indisponível</span>
            </label>
          </div>
        </div>

        <!-- Dias disponíveis -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Dias disponíveis</label>
          <div class="flex flex-wrap gap-2">
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaSeg" checked class="w-4 h-4"> <span class="text-sm">Seg</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaTer" checked class="w-4 h-4"> <span class="text-sm">Ter</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaQua" checked class="w-4 h-4"> <span class="text-sm">Qua</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaQui" checked class="w-4 h-4"> <span class="text-sm">Qui</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaSex" checked class="w-4 h-4"> <span class="text-sm">Sex</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaSab" checked class="w-4 h-4"> <span class="text-sm">Sáb</span>
            </label>
            <label class="flex items-center gap-1 bg-gray-100 px-3 py-1 rounded-lg cursor-pointer hover:bg-gray-200">
              <input type="checkbox" id="diaDom" checked class="w-4 h-4"> <span class="text-sm">Dom</span>
            </label>
          </div>
        </div>

        <!-- Botões -->
        <div class="flex gap-3 pt-2">
          <button 
            type="button"
            onclick="fecharModal()"
            class="flex-1 py-3 border border-gray-300 rounded-xl font-medium hover:bg-gray-50"
          >
            Cancelar
          </button>
          <button 
            type="submit"
            id="btnSalvar"
            class="flex-1 py-3 btn-green text-white rounded-xl font-medium flex items-center justify-center gap-2"
          >
            <span id="btnSalvarText">💾 Salvar</span>
            <svg id="btnSalvarSpinner" class="w-5 h-5 spinner hidden" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </div>
      </form>

    </div>
  </div>

  <!-- Modal Confirmar Exclusão -->
  <div id="modalExcluir" class="fixed inset-0 bg-black/50 hidden items-center justify-center p-4 z-50">
    <div class="bg-white rounded-2xl w-full max-w-sm card-shadow fade-in p-6 text-center">
      <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <span class="text-3xl">🗑️</span>
      </div>
      <h3 class="font-bold text-lg mb-2">Excluir produto?</h3>
      <p class="text-gray-500 mb-4" id="excluirNome">Tem certeza que deseja excluir este produto?</p>
      <div class="flex gap-3">
        <button onclick="fecharModalExcluir()" class="flex-1 py-3 border border-gray-300 rounded-xl font-medium hover:bg-gray-50">
          Cancelar
        </button>
        <button onclick="confirmarExclusao()" id="btnExcluir" class="flex-1 py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl font-medium">
          🗑️ Excluir
        </button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-4 right-4 bg-gray-800 text-white px-6 py-3 rounded-xl shadow-lg hidden fade-in">
    <span id="toastMsg">Mensagem</span>
  </div>

  <script>
    // ==================== CONFIGURAÇÃO ====================
    const WEBHOOK_URL = 'https://webhook.quetal.me/webhook/eProdutos';
    
    // ==================== ESTADO ====================
    let produtos = [];
    let produtosFiltrados = [];
    let categorias = new Set();
    let produtoExcluir = null;
    let idPlanilha = '';
    let nomeEmpresa = '';

    // ==================== INICIALIZAÇÃO ====================
    document.addEventListener('DOMContentLoaded', function() {
      // Pegar parâmetros da URL
      const params = new URLSearchParams(window.location.search);
      idPlanilha = params.get('id') || '';
      
      if (!idPlanilha) {
        mostrarErro('ID da planilha não informado');
        return;
      }
      
      carregarProdutos();
      
      document.getElementById('formProduto').addEventListener('submit', salvarProduto);
    });

    // ==================== API ====================
    async function carregarProdutos() {
      try {
        const response = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            acao: 'listar',
            idPlanilha: idPlanilha 
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          produtos = data.produtos || [];
          nomeEmpresa = data.nomeEmpresa || 'Minha Loja';
          
          document.getElementById('headerSubtitle').textContent = nomeEmpresa;
          
          // Extrair categorias
          categorias.clear();
          produtos.forEach(p => {
            if (p.Sessão || p.Sessao) categorias.add(p.Sessão || p.Sessao);
          });
          
          atualizarFiltroCategoria();
          filtrarProdutos();
        } else {
          mostrarErro(data.message || 'Erro ao carregar produtos');
        }
        
      } catch (error) {
        console.error('Erro:', error);
        mostrarErro('Erro de conexão');
      }
      
      document.getElementById('loading').classList.add('hidden');
    }

    async function salvarProduto(e) {
      e.preventDefault();
      
      const btn = document.getElementById('btnSalvar');
      const btnText = document.getElementById('btnSalvarText');
      const btnSpinner = document.getElementById('btnSalvarSpinner');
      
      btn.disabled = true;
      btnText.textContent = 'Salvando...';
      btnSpinner.classList.remove('hidden');
      
      try {
        const produtoId = document.getElementById('produtoId').value;
        const produtoRow = document.getElementById('produtoRow').value;
        
        const dados = {
          acao: produtoId ? 'atualizar' : 'criar',
          idPlanilha: idPlanilha,
          produto: {
            ID_Produto: produtoId || gerarId(),
            row_number: produtoRow || null,
            Nome_Produto: document.getElementById('produtoNome').value,
            Preco_Guarani: document.getElementById('produtoPreco').value.replace(/\D/g, ''),
            Sessão: document.getElementById('produtoCategoria').value,
            Descricao: document.getElementById('produtoDescricao').value,
            Status: document.querySelector('input[name="produtoStatus"]:checked').value,
            Seg: document.getElementById('diaSeg').checked ? 'TRUE' : 'FALSE',
            Ter: document.getElementById('diaTer').checked ? 'TRUE' : 'FALSE',
            Qua: document.getElementById('diaQua').checked ? 'TRUE' : 'FALSE',
            Qui: document.getElementById('diaQui').checked ? 'TRUE' : 'FALSE',
            Sex: document.getElementById('diaSex').checked ? 'TRUE' : 'FALSE',
            Sab: document.getElementById('diaSab').checked ? 'TRUE' : 'FALSE',
            Dom: document.getElementById('diaDom').checked ? 'TRUE' : 'FALSE'
          }
        };
        
        const response = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dados)
        });
        
        if (response.ok) {
          mostrarToast(produtoId ? '✅ Produto atualizado!' : '✅ Produto criado!');
          fecharModal();
          carregarProdutos();
        } else {
          throw new Error('Erro ao salvar');
        }
        
      } catch (error) {
        console.error('Erro:', error);
        mostrarToast('❌ Erro ao salvar produto');
      }
      
      btn.disabled = false;
      btnText.textContent = '💾 Salvar';
      btnSpinner.classList.add('hidden');
    }

    async function confirmarExclusao() {
      if (!produtoExcluir) return;
      
      const btn = document.getElementById('btnExcluir');
      btn.disabled = true;
      btn.textContent = 'Excluindo...';
      
      try {
        const response = await fetch(WEBHOOK_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            acao: 'excluir',
            idPlanilha: idPlanilha,
            idProduto: produtoExcluir.ID_Produto,
            rowNumber: produtoExcluir.row_number
          })
        });
        
        if (response.ok) {
          mostrarToast('✅ Produto excluído!');
          fecharModalExcluir();
          carregarProdutos();
        } else {
          throw new Error('Erro ao excluir');
        }
        
      } catch (error) {
        console.error('Erro:', error);
        mostrarToast('❌ Erro ao excluir produto');
      }
      
      btn.disabled = false;
      btn.textContent = '🗑️ Excluir';
    }

    // ==================== UI ====================
    function renderizarProdutos() {
      const container = document.getElementById('listaProdutos');
      const vazio = document.getElementById('vazio');
      
      if (produtosFiltrados.length === 0) {
        container.innerHTML = '';
        vazio.classList.remove('hidden');
        return;
      }
      
      vazio.classList.add('hidden');
      
      // Agrupar por categoria
      const porCategoria = {};
      produtosFiltrados.forEach(p => {
        const cat = p.Sessão || p.Sessao || 'Outros';
        if (!porCategoria[cat]) porCategoria[cat] = [];
        porCategoria[cat].push(p);
      });
      
      let html = '';
      
      Object.keys(porCategoria).sort().forEach(cat => {
        html += `
          <div class="mb-4">
            <h3 class="font-semibold text-gray-600 mb-2 flex items-center gap-2">
              <span class="w-2 h-2 bg-green-500 rounded-full"></span>
              ${cat} (${porCategoria[cat].length})
            </h3>
            <div class="space-y-2">
        `;
        
        porCategoria[cat].forEach(p => {
          const disponivel = p.Status === 'Disponível';
          html += `
            <div class="bg-white rounded-xl p-4 card-shadow product-card transition-all flex items-center gap-4 ${!disponivel ? 'opacity-60' : ''}">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-lg">${disponivel ? '✅' : '❌'}</span>
                  <h4 class="font-medium truncate">${p.Nome_Produto}</h4>
                </div>
                <p class="text-green-600 font-semibold">Gs. ${formatarNumero(p.Preco_Guarani)}</p>
                ${p.Descricao ? `<p class="text-gray-400 text-sm truncate">${p.Descricao}</p>` : ''}
              </div>
              <div class="flex gap-2">
                <button onclick='editarProduto(${JSON.stringify(p)})' class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg" title="Editar">
                  ✏️
                </button>
                <button onclick='abrirModalExcluir(${JSON.stringify(p)})' class="p-2 text-red-500 hover:bg-red-50 rounded-lg" title="Excluir">
                  🗑️
                </button>
              </div>
            </div>
          `;
        });
        
        html += `</div></div>`;
      });
      
      container.innerHTML = html;
    }

    function filtrarProdutos() {
      const busca = document.getElementById('busca').value.toLowerCase();
      const categoria = document.getElementById('filtroCategoria').value;
      const status = document.getElementById('filtroStatus').value;
      
      produtosFiltrados = produtos.filter(p => {
        const matchBusca = !busca || 
          (p.Nome_Produto && p.Nome_Produto.toLowerCase().includes(busca)) ||
          (p.Descricao && p.Descricao.toLowerCase().includes(busca));
        
        const matchCategoria = !categoria || (p.Sessão || p.Sessao) === categoria;
        const matchStatus = !status || p.Status === status;
        
        return matchBusca && matchCategoria && matchStatus;
      });
      
      renderizarProdutos();
    }

    function atualizarFiltroCategoria() {
      const select = document.getElementById('filtroCategoria');
      const datalist = document.getElementById('categoriasLista');
      
      // Limpar
      select.innerHTML = '<option value="">Todas categorias</option>';
      datalist.innerHTML = '';
      
      // Adicionar categorias
      Array.from(categorias).sort().forEach(cat => {
        select.innerHTML += `<option value="${cat}">${cat}</option>`;
        datalist.innerHTML += `<option value="${cat}">`;
      });
    }

    // ==================== MODAL ====================
    function abrirModal() {
      document.getElementById('modal').classList.remove('hidden');
      document.getElementById('modal').classList.add('flex');
      document.getElementById('modalTitulo').textContent = 'Novo Produto';
      document.getElementById('formProduto').reset();
      document.getElementById('produtoId').value = '';
      document.getElementById('produtoRow').value = '';
      
      // Marcar todos os dias
      ['Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sab', 'Dom'].forEach(dia => {
        document.getElementById('dia' + dia).checked = true;
      });
    }

    function fecharModal() {
      document.getElementById('modal').classList.add('hidden');
      document.getElementById('modal').classList.remove('flex');
    }

    function editarProduto(p) {
      document.getElementById('modal').classList.remove('hidden');
      document.getElementById('modal').classList.add('flex');
      document.getElementById('modalTitulo').textContent = 'Editar Produto';
      
      document.getElementById('produtoId').value = p.ID_Produto || '';
      document.getElementById('produtoRow').value = p.row_number || '';
      document.getElementById('produtoNome').value = p.Nome_Produto || '';
      document.getElementById('produtoPreco').value = formatarNumero(p.Preco_Guarani);
      document.getElementById('produtoCategoria').value = p.Sessão || p.Sessao || '';
      document.getElementById('produtoDescricao').value = p.Descricao || '';
      
      document.querySelector(`input[name="produtoStatus"][value="${p.Status || 'Disponível'}"]`).checked = true;
      
      document.getElementById('diaSeg').checked = p.Seg === 'TRUE' || p.Seg === true;
      document.getElementById('diaTer').checked = p.Ter === 'TRUE' || p.Ter === true;
      document.getElementById('diaQua').checked = p.Qua === 'TRUE' || p.Qua === true;
      document.getElementById('diaQui').checked = p.Qui === 'TRUE' || p.Qui === true;
      document.getElementById('diaSex').checked = p.Sex === 'TRUE' || p.Sex === true;
      document.getElementById('diaSab').checked = p.Sab === 'TRUE' || p.Sab === true;
      document.getElementById('diaDom').checked = p.Dom === 'TRUE' || p.Dom === true;
    }

    function abrirModalExcluir(p) {
      produtoExcluir = p;
      document.getElementById('excluirNome').textContent = `Excluir "${p.Nome_Produto}"?`;
      document.getElementById('modalExcluir').classList.remove('hidden');
      document.getElementById('modalExcluir').classList.add('flex');
    }

    function fecharModalExcluir() {
      document.getElementById('modalExcluir').classList.add('hidden');
      document.getElementById('modalExcluir').classList.remove('flex');
      produtoExcluir = null;
    }

    // ==================== UTILS ====================
    function gerarId() {
      return Date.now().toString(36).toUpperCase();
    }

    function formatarNumero(num) {
      return Number(num || 0).toLocaleString('es-PY');
    }

    function formatarPreco(input) {
      let valor = input.value.replace(/\D/g, '');
      input.value = Number(valor).toLocaleString('es-PY');
    }

    function mostrarToast(msg) {
      const toast = document.getElementById('toast');
      document.getElementById('toastMsg').textContent = msg;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    }

    function mostrarErro(msg) {
      document.getElementById('loading').innerHTML = `
        <span class="text-4xl">⚠️</span>
        <p class="text-red-500 mt-2">${msg}</p>
      `;
    }
  </script>

</body>
</html>
